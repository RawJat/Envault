{
  "name": "@dinanathdash/envault-mcp-server",
  "version": "1.12.0",
  "mcpName": "io.github.DinanathDash/envault",
  "type": "module",
  "description": "MCP server for Envault CLI operations",
  "license": "SEE LICENSE IN LICENSE",
  "keywords": [
    "mcp",
    "mcp-server",
    "model-context-protocol",
    "claude",
    "secrets-management",
    "envault"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/DinanathDash/Envault"
  },
  "main": "server.mjs",
  "bin": {
    "envault-mcp-server": "server.mjs"
  },
  "files": [
    "server.mjs",
    "README.md",
    "postinstall.mjs",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node server.mjs",
    "version": "node server.mjs --version",
    "check:update": "node server.mjs --check-update",
    "check": "node --check server.mjs",
    "test:postinstall": "node --test postinstall.test.mjs",
    "prepublishOnly": "npm run check",
    "postinstall": "node postinstall.mjs"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.3"
  }
}
