{
  "name": "@dinanathdash/envault-mcp-server",
  "version": "1.0.2",
  "type": "module",
  "description": "MCP server for Envault CLI operations",
  "repository": {
    "type": "git",
    "url": "https://github.com/DinanathDash/Envault"
  },
  "main": "server.mjs",
  "bin": {
    "envault-mcp-server": "server.mjs"
  },
  "files": [
    "server.mjs",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
