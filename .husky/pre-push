#!/usr/bin/env sh
# Envault pre-push hook — enforces changeset documentation before pushing.
# Blocks pushes to main/master that have no pending changeset entry.

BRANCH=$(git rev-parse --abbrev-ref HEAD)

if [ "$BRANCH" = "main" ] || [ "$BRANCH" = "master" ]; then
  echo "🔒 Envault: Running changeset status check before push to $BRANCH..."
  npx --no-install changeset status --since=main
  STATUS=$?
  if [ $STATUS -ne 0 ]; then
    echo ""
    echo "❌ Push blocked: No changeset found for your changes."
    echo "   Run 'npx changeset' to document your changes, then push again."
    exit 1
  fi
  echo "✅ Changeset check passed."
fi
